# AgentHub Environment Configuration
# Copy this file to .env.local and fill in the values

# Server Configuration
PORT=3002
NODE_ENV=development

# Frontend Runtime Configuration
# Local dev can keep these values. In Vercel production, point them to your backend server.
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WS_URL=ws://localhost:3002/api/ws

# Database Configuration
# Production requires PostgreSQL with pgvector enabled.
DATABASE_URL=postgresql://agenthub:password@localhost:5432/agenthub?schema=public

# LLM Configuration
ADAPTER_TYPE=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# CORS Configuration
CORS_ORIGIN=http://localhost:3003

# Session Configuration
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL_DAYS=7

# File Upload Configuration
UPLOAD_DIR=./packages/server/db/files
MAX_FILE_SIZE_MB=100

# Tool API Keys (Optional)
TAVILY_API_KEY=your_tavily_api_key_here
E2B_API_KEY=your_e2b_api_key_here
VERCEL_TOKEN=your_vercel_token_here

# Self-hosted Default Deployment Target (Optional)
# These values configure the shared AgentHub default server for all users.
# Individual users can still add their own SSH server from the UI without these.
DEPLOYMENT_TARGET_SECRET=replace-with-another-long-random-secret
SELF_HOSTED_SSH_HOST=your_server_ip_or_domain
SELF_HOSTED_SSH_PORT=22
SELF_HOSTED_SSH_USER=deploy
SELF_HOSTED_SSH_KEY=/home/agenthub/.ssh/agenthub_default
SELF_HOSTED_DEPLOY_PATH=/var/www/agenthub-sites/{userId}/{deployId}
SELF_HOSTED_PUBLIC_URL=http://your_server_ip_or_domain/{userId}/{deployId}
# SELF_HOSTED_POST_DEPLOY_COMMAND=sudo -n nginx -s reload

# Claude Code Configuration (Optional)
CLAUDE_CODE_PATH=claude

# Codex Configuration (Optional)
CODEX_PATH=codex
