{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "noEmit": false,
    "paths": {
      "@agenthub/shared": ["../shared/src"],
      "@agenthub/adapter": ["../adapter/src"]
    }
  },
  "include": ["src/**/*.ts"]
}
